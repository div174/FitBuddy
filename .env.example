# ─────────────────────────────────────────────────────────────────
# FitBuddy – Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────

# 🗝️ Google Gemini API Key (Required)
# Get yours free at: https://aistudio.google.com/app/apikey
# For High Availability: Provide multiple keys separated by commas
# Example: GOOGLE_API_KEY=key1,key2,key3
GOOGLE_API_KEY=YOUR_GEMINI_API_KEY_HERE

# 🗄️ Database (Optional, defaults to local SQLite)
DATABASE_URL=sqlite+aiosqlite:///./fitbuddy.db

# 🌐 Server Settings
HOST=0.0.0.0
PORT=8000
DEBUG=false